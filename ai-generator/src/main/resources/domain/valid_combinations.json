  "leg_composition_rules": [
    {
      "family": "ACQUIRING",
      "type": "AUTH",
      "legs": [
        "1x AUTH_HOLD (CLIENT_ENTITY -> CKO_ENTITY)"
      ]
    },
    {
      "family": "ACQUIRING",
      "type": "CAPTURE",
      "legs": [
        "1x SCHEME_SETTLEMENT (SCHEME -> CKO_ENTITY)",
        "1x FUNDING (CKO_ENTITY -> CLIENT_ENTITY)",
        "Cross-entity: additional TRANSFER trade (separate trade, not additional leg)"
      ]
    },
    {
      "family": "ACQUIRING",
      "type": "REFUND",
      "legs": [
        "1x SCHEME_SETTLEMENT (CKO_ENTITY -> SCHEME)",
        "1x FUNDING (CLIENT_ENTITY -> CKO_ENTITY)"
      ]
    },
    {
      "family": "ACQUIRING",
      "type": "CHARGEBACK",
      "legs": [
        "1x SCHEME_SETTLEMENT (reversed direction)",
        "1x FUNDING (reversed direction)"
      ]
    },
    {
      "family": "PAYOUT",
      "type": "CREDIT",
      "legs": [
        "1x FUNDING (CKO_ENTITY -> CLIENT_ENTITY)"
      ]
    },
    {
      "family": "TOPUP",
      "type": "CREDIT",
      "legs": [
        "1x FUNDING (CLIENT_ENTITY -> CKO_ENTITY)"
      ]
    },
    {
      "family": "FX",
      "type": "CONVERSION",
      "legs": [
        "1x FX_CONVERSION (CKO_ENTITY -> CKO_ENTITY, different currencies)"
      ]
    },
    {
      "family": "TRANSFER",
      "type": "DEBIT",
      "legs": [
        "1x ENTITY_TRANSFER (CKO_ENTITY -> CKO_ENTITY)",
        "or 1x FUNDING (CLIENT_ENTITY -> CLIENT_ENTITY for reserve/collateral)"
      ]
    },
    {
      "family": "TRANSFER",
      "type": "CREDIT",
      "legs": [
        "1x ENTITY_TRANSFER (CKO_ENTITY -> CKO_ENTITY)",
        "or 1x FUNDING (CLIENT_ENTITY -> CLIENT_ENTITY for reserve/collateral)"
      ]
    },
    {
      "family": "CASH",
      "type": "*",
      "legs": [
        "1x FUNDING"
      ]
    }
